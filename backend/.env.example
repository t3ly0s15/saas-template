# ── Auth ──────────────────────────────────────────────────────────────────────
# Générer avec : python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-this-to-a-random-64-char-hex-secret

# ── Base de données ────────────────────────────────────────────────────────────
DB_PATH=/data/saas.db

# ── URL de l'application ───────────────────────────────────────────────────────
# Utilisée pour construire les liens confirm/cancel dans les emails
APP_URL=http://localhost:8000

# ── Google OAuth2 (Calendar + Gmail) ─────────────────────────────────────────
# 1. Créer un projet sur https://console.cloud.google.com/
# 2. Activer les APIs : Google Calendar API et Gmail API
# 3. Créer des identifiants OAuth2 (type "Application Web")
# 4. Ajouter l'URI de redirection : {APP_URL}/api/integrations/google/callback
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your-client-secret
